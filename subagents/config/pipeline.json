{
  "provider": "openrouter",
  "require_llm": true,
  "base_url": "https://openrouter.ai/api/v1",
  "model_writer": "anthropic/claude-sonnet-4.6",
  "model_critic": "openai/gpt-5.2",
  "model_orchestrator": "openai/gpt-5.2",
  "temperature_writer": 0.3,
  "temperature_critic": 0.1,
  "temperature_orchestrator": 0.1,
  "max_tokens_writer": 16000,
  "max_tokens_critic": 16000,
  "max_tokens_orchestrator": 4000,
  "request_timeout_s": 45,
  "request_retries": 1,
  "batch_size": 25,
  "max_iterations": 4,
  "json_only": true,
  "difficulty_distribution": {
    "easy_1_2": 0.3,
    "medium_3": 0.5,
    "hard_4_5": 0.2
  },
  "pilot_categories": [
    "category-04-world-capitals-countries.json",
    "category-19-quotes-proverbs.json"
  ]
}
