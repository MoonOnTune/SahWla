generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentProvider {
  U_PAYMENTS
}

enum PaymentOrderStatus {
  CREATED
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum GameSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CreditReason {
  PURCHASE
  GAME_START
  REFUND
  BONUS
}

enum GameMode {
  CLASSIC
  SPECIAL
}

enum GameRoomStatus {
  SETUP
  ACTIVE
  COMPLETED
  CANCELLED
}

enum GameRoomPhase {
  QR
  BOARD
  QUESTION
  ANSWER
  WINNER
}

enum GameTeamKey {
  A
  B
}

enum GameParticipantRole {
  CAPTAIN
  MEMBER
}

enum GameAbilityType {
  STEAL
  DOUBLE_POINTS
  SHIELD
  BONUS_PICK
  POINT_THEFT
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  accounts       Account[]
  sessions       Session[]
  wallet         CreditWallet?
  ledger         CreditLedger[]
  paymentOrders  PaymentOrder[]
  gameSessions   GameSession[]
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id            String         @id @default(cuid())
  sku           String         @unique
  name          String
  description   String?
  price_kwd     Decimal        @db.Decimal(10, 3)
  credit_amount Int
  active        Boolean        @default(true)
  orders        PaymentOrder[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
}

model PaymentOrder {
  id                  String            @id @default(cuid())
  provider            PaymentProvider
  external_order_id   String            @unique
  track_id            String?           @unique
  status              PaymentOrderStatus @default(CREATED)
  amount_kwd          Decimal           @db.Decimal(10, 3)
  requested_credits   Int               @default(0)
  unit_price_kwd      Decimal           @default(0.000) @db.Decimal(10, 3)
  coupon_code         String?
  discount_kwd        Decimal           @default(0.000) @db.Decimal(10, 3)
  currency            String            @default("KWD")
  payment_url         String?
  product_id          String
  user_id             String
  paid_at             DateTime?
  verified_at         DateTime?
  raw_create_response Json?
  raw_verify_response Json?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  product Product @relation(fields: [product_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([track_id])
  @@index([status])
}

model PaymentEvent {
  id           String          @id @default(cuid())
  provider     PaymentProvider
  event_id     String          @unique
  payload      Json
  track_id     String?
  processed_at DateTime?
  created_at   DateTime        @default(now())

  @@index([track_id])
  @@index([provider])
}

model CreditWallet {
  id         String   @id @default(cuid())
  user_id    String   @unique
  balance    Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id         String       @id @default(cuid())
  user_id    String
  delta      Int
  reason     CreditReason
  ref_type   String?
  ref_id     String?
  created_at DateTime     @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at(sort: Desc)])
  @@unique([user_id, reason, ref_type, ref_id])
}

model GameSession {
  id         String            @id @default(cuid())
  user_id    String
  status     GameSessionStatus @default(ACTIVE)
  started_at DateTime          @default(now())
  ended_at   DateTime?
  metadata   Json?
  picks      GameQuestionPick[]
  room       GameRoom?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
  @@index([started_at])
}

model Question {
  id            String             @id @default(cuid())
  category_name String
  value         Int
  text_hash     String
  question_text String
  answer_text   String
  active        Boolean            @default(true)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  picks         GameQuestionPick[]

  @@unique([category_name, value, text_hash])
  @@index([category_name, value, active])
}

model GameQuestionPick {
  id              String    @id @default(cuid())
  game_session_id String
  category_name   String
  value           Int
  slot_index      Int
  question_id     String
  used_at         DateTime?
  created_at      DateTime  @default(now())

  pendingForRooms  GameRoom[] @relation("PendingRoomPick")
  selectedForRooms GameRoom[] @relation("SelectedRoomPick")

  gameSession GameSession @relation(fields: [game_session_id], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [question_id], references: [id], onDelete: Restrict)

  @@unique([game_session_id, category_name, value, slot_index])
  @@index([game_session_id])
  @@index([question_id])
  @@index([game_session_id, category_name, value, used_at])
}

model GameRoom {
  id                        String            @id @default(cuid())
  game_session_id           String            @unique
  mode                      GameMode          @default(SPECIAL)
  room_code                 String            @unique
  status                    GameRoomStatus    @default(SETUP)
  phase                     GameRoomPhase     @default(QR)
  daily_double_enabled      Boolean           @default(true)
  board_categories          String[]
  current_turn_team         GameTeamKey       @default(A)
  current_round             Int               @default(1)
  ability_used_by_a_round   Int               @default(0)
  ability_used_by_b_round   Int               @default(0)
  pending_suggested_pick_id String?
  selected_pick_id          String?
  started_at                DateTime          @default(now())
  ended_at                  DateTime?
  created_at                DateTime          @default(now())
  updated_at                DateTime          @updatedAt

  gameSession          GameSession        @relation(fields: [game_session_id], references: [id], onDelete: Cascade)
  pendingSuggestedPick GameQuestionPick?  @relation("PendingRoomPick", fields: [pending_suggested_pick_id], references: [id], onDelete: SetNull)
  selectedPick         GameQuestionPick?  @relation("SelectedRoomPick", fields: [selected_pick_id], references: [id], onDelete: SetNull)
  teams                GameRoomTeam[]
  participants         GameRoomParticipant[]
  chatMessages         GameRoomChatMessage[]
  abilities            GameRoomAbility[]
  events               GameRoomEvent[]

  @@index([room_code, status])
  @@index([game_session_id, status])
}

model GameRoomTeam {
  id                    String      @id @default(cuid())
  room_id               String
  team_key              GameTeamKey
  name                  String
  color                 String
  color_light           String
  score                 Int         @default(0)
  correct_streak        Int         @default(0)
  captain_participant_id String?
  pending_double_points Boolean     @default(false)
  pending_bonus_pick    Boolean     @default(false)
  pending_steal         Boolean     @default(false)
  shield_count          Int         @default(0)
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  room GameRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@unique([room_id, team_key])
  @@index([room_id])
}

model GameRoomParticipant {
  id            String              @id @default(cuid())
  room_id       String
  team_key      GameTeamKey
  nickname      String
  role          GameParticipantRole @default(MEMBER)
  device_token  String
  connected_at  DateTime            @default(now())
  last_seen_at  DateTime            @default(now())
  disconnected_at DateTime?
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt

  room GameRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@unique([room_id, device_token])
  @@index([room_id, team_key])
  @@index([room_id, role])
}

model GameRoomChatMessage {
  id             String      @id @default(cuid())
  room_id        String
  team_key       GameTeamKey
  participant_id String
  message        String      @db.Text
  created_at     DateTime    @default(now())

  room GameRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([room_id, team_key, created_at])
  @@index([participant_id])
}

model GameRoomAbility {
  id             String          @id @default(cuid())
  room_id        String
  team_key       GameTeamKey
  ability_type   GameAbilityType
  unlocked_round Int
  consumed_at    DateTime?
  created_at     DateTime        @default(now())

  room GameRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([room_id, team_key, consumed_at])
  @@index([room_id, unlocked_round])
}

model GameRoomEvent {
  id         String      @id @default(cuid())
  room_id    String
  team_key   GameTeamKey?
  event_type String
  message    String
  payload    Json?
  created_at DateTime    @default(now())

  room GameRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([room_id, created_at])
  @@index([room_id, team_key, created_at])
}
