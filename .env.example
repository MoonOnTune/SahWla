# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-strong-random-secret
NEXTAUTH_SECRET=replace-with-the-same-strong-random-secret
AUTH_TRUST_HOST=true

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/sahwala?schema=public

# Realtime (choose one)
# Self-hosted soketi
SOKETI_APP_ID=app-id
SOKETI_APP_KEY=app-key
SOKETI_APP_SECRET=app-secret
SOKETI_HOST=soketi
SOKETI_PORT=6001
SOKETI_USE_TLS=false
NEXT_PUBLIC_SOKETI_APP_KEY=app-key
NEXT_PUBLIC_SOKETI_HOST=localhost
NEXT_PUBLIC_SOKETI_PORT=6001
NEXT_PUBLIC_SOKETI_TLS=false

# Hosted Pusher (optional fallback)
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=

# OAuth - Google (required in production)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - Apple (stub/TODO)
APPLE_ID=your-apple-service-id
APPLE_CLIENT_SECRET=your-apple-client-secret
# TODO if your Apple setup requires JWT generation, add APPLE_TEAM_ID/APPLE_KEY_ID/APPLE_PRIVATE_KEY and generate the secret externally

# Email Magic Link via SMTP (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM="Sah Wala <no-reply@sahwala.local>"
SMTP_SECURE=false

# UPayments
# sandbox (recommended for testing) or live
UPAYMENTS_MODE=sandbox
# Optional: override mode defaults (sandbox: https://sandboxapi.upayments.com, live: https://api.upayments.com)
UPAYMENTS_BASE_URL=https://sandboxapi.upayments.com
# Optional: fail fast instead of waiting ~60s on provider timeouts
UPAYMENTS_TIMEOUT_MS=20000
UPAYMENTS_API_KEY=your-upayments-api-key
UPAYMENTS_LANGUAGE=ar
UPAYMENTS_RETURN_URL=http://localhost:3000/shop?payment=return
UPAYMENTS_CANCEL_URL=http://localhost:3000/shop?payment=cancel
UPAYMENTS_WEBHOOK_URL=http://localhost:3000/api/webhooks/upayments

# Optional webhook signature verification
UPAYMENTS_WEBHOOK_SECRET=
UPAYMENTS_WEBHOOK_SIGNATURE_HEADER=x-upayments-signature

# Demo credentials seed (optional)
DEMO_USER_EMAIL=demo@sahwala.local
DEMO_USER_PASSWORD=DemoPass123
